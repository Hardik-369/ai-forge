# AI-Forge Configuration
# ============================================================================
# Copy this file to .env and customize before running docker compose up
# ============================================================================

# Domain Configuration (required for Traefik/SSL)
DOMAIN=ai-forge.local
CERT_EMAIL=admin@example.com

# Traefik Dashboard
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_AUTH=admin:$2y$10$...

# Open WebUI
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=change-me-to-a-random-string

# n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change-me-to-a-random-key
N8N_USER_MANAGEMENT_JWT_SECRET=change-me-to-another-random-key
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=password

# Ollama
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2

# Qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change-me-to-a-secure-api-key

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=ai_forge
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=ai_forge

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-another-password

# Monitoring
GRAFANA_PORT=3001
UPTIME_KUMA_PORT=3002

# Timezone
TZ=UTC

# Resource Limits
MEMORY_LIMIT_AI=4g
MEMORY_LIMIT_DB=1g
MEMORY_LIMIT_AUTOMATION=512m
MEMORY_LIMIT_PROXY=256m
MEMORY_LIMIT_MONITORING=256m

# Network
DOCKER_NETWORK=ai-forge-network
